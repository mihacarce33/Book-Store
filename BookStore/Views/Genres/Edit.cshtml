@model BookStore.Models.Genre

@{
    ViewBag.Title = "Edit Genre";
}

<h2 class="text-center mb-4">Edit Genre</h2>

<div class="container">
    <div class="card shadow-sm p-4">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <h4 class="mb-4">Genre Details</h4>
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
            @Html.HiddenFor(model => model.Id)

            <div class="mb-3 row">
                @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "col-form-label col-md-2 fw-bold" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <input type="submit" value="Save" class="btn btn-primary me-2" />
                @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary" })
            </div>
        }
    </div>
</div>
