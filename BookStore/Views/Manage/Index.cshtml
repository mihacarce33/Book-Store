@model BookStore.Models.IndexViewModel
@{
    ViewBag.Title = "Manage";
}

<main aria-labelledby="title" class="container mt-4">
    <h2 id="title" class="text-center mb-4">@ViewBag.Title</h2>

    @if (!string.IsNullOrEmpty(ViewBag.StatusMessage))
    {
        <div class="alert alert-success" role="alert">
            @ViewBag.StatusMessage
        </div>
    }

    <div class="card shadow-lg p-4 rounded-4">
        <h4 class="mb-3">Change your account settings</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-4">Password:</dt>
            <dd class="col-sm-8">
                @if (Model.HasPassword)
                {
                    <a href="@Url.Action("ChangePassword")" class="btn btn-outline-primary btn-sm">
                        Change your password
                    </a>
                }
                else
                {
                    <a href="@Url.Action("SetPassword")" class="btn btn-outline-secondary btn-sm">
                        Create Password
                    </a>
                }
            </dd>
        </dl>
    </div>
</main>
