@{
    ViewBag.Title = "Visit Us";
}

<section class="page-hero">
    <h1 class="display-5">Visit Us</h1>
    <p class="hero-lead">The shop door is heavy oak for a reason — what lies within is worth the pause.</p>
</section>

<div class="row g-4">
    <div class="col-md-6">
        <div class="content-section h-100">
            <h3>At the desk</h3>
            <div class="contact-info-card mt-3">
                <address>
                    <p style="font-family: var(--font-caps); font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 0.25rem;">Proprietor</p>
                    <p style="font-family: var(--font-display); font-size: 1.25rem; margin-bottom: 1.5rem;">Blackwood & Co. Books</p>

                    <p style="font-family: var(--font-caps); font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 0.25rem;">Registry</p>
                    <p style="margin-bottom: 0;">Patron no. 123456</p>
                </address>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-section h-100">
            <h3>Correspondence</h3>
            <p class="text-muted" style="font-style: italic;">
                For inquiries regarding availability, condition reports, or holding a volume,
                you may reach us through the usual channels.
            </p>
            <a target="_blank" rel="noopener" class="btn btn-outline-primary mt-2">
                Blackwood & Co. Books
            </a>
        </div>
    </div>
</div>
