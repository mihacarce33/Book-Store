@{
    ViewBag.Title = "Contact Us";
    ViewBag.Message = "Get in touch with us for support or inquiries.";
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - BookStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
</head>
<main aria-labelledby="title">
    <!-- Contact Header Section -->
    <section class="bg-light p-5 rounded shadow-sm mb-4">
        <h2 id="title" class="text-center display-4 fw-bold mb-3">@ViewBag.Title</h2>
        <h3 class="text-center text-muted">@ViewBag.Message</h3>
    </section>

    <!-- Contact Information Section -->
    <section class="container">
        <div class="row">
            <!-- Contact Info Column -->
            <div class="col-md-6">
                <h4 class="fw-bold">Contact Information</h4>
                <address>
                    <strong>Name:</strong><br />
                    Mihail<br />
                    <strong>Surame:</strong><br />
                    Petrov
                </address>
            </div>

            <!-- Additional Info Column -->
            <div class="col-md-6">
                <h4 class="fw-bold">Additional Info</h4>
                <p><strong>Student Index:</strong> 221144</p>
                <p>
                    <strong>Follow Us:</strong><br />
                    <a href="https://www.instagram.com/petrovmihail10" target="_blank" class="btn btn-outline-primary btn-sm">
                        <i class="fab fa-instagram"></i> petrovmihail10
                    </a>

                </p>
            </div>
        </div>
    </section>
</main>

<!-- FontAwesome for Instagram Icon -->
<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
