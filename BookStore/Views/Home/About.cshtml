@{
    ViewBag.Title = "About Us";
    ViewBag.Message = "Learn more about our company and mission.";
}

<main aria-labelledby="title">
    <!-- Hero Section -->
    <section class="bg-light p-5 rounded shadow-sm mb-4">
        <h2 id="title" class="text-center display-4 fw-bold mb-3">@ViewBag.Title</h2>
        <h3 class="text-center text-muted">@ViewBag.Message</h3>
    </section>

    <!-- About Content Section -->
    <section class="container">
        <div class="row align-items-center">
            <div class="col-md-6 mb-4">
                <h4 class="fw-bold">Our Story</h4>
                <p>
                    We started our journey with the goal of providing the best service in the industry. Our team is passionate about creating solutions that make a real difference for our customers.
                </p>
                <h4 class="fw-bold">Our Mission</h4>
                <p>
                    To deliver high-quality services and products that exceed our customers' expectations, foster innovation, and promote a culture of excellence.
                </p>
            </div>
            <div class="col-md-6">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS6IugSOE4YFNfRKis-N_gkVzo3ai0E2GgLfQ&s" alt="About Us" class="img-fluid rounded shadow-sm">
            </div>
        </div>
    </section>

    <!-- Call to Action Section -->
    <section class="text-center bg-dark text-white p-4 mt-5 rounded shadow-sm">
        <h5>Want to learn more about us?</h5>
        <p class="mb-3">Feel free to contact us or explore our services!</p>
        <a href="/Home/Contact" class="btn btn-primary btn-lg">Contact Us</a>
    </section>
</main>
