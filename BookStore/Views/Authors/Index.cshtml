@model IEnumerable<BookStore.Models.Author>

@{
    ViewBag.Title = "Authors";
}

<section class="page-hero page-hero-light">
    <h1 class="display-5" style="font-size: 2rem;">Authors &amp; Makers of Text</h1>
    <p class="hero-lead">Those whose words have earned a place in our catalogue.</p>
</section>

@if (User.IsInRole("Admin"))
{
    <div class="d-flex justify-content-end mb-4">
        @Html.ActionLink("Add to the register", "Create", null, new { @class = "btn btn-gold" })
    </div>
}

<div class="data-card p-0">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col"></th>
                    <th scope="col">Name</th>
                    <th scope="col">Biography</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th scope="col" class="text-end">Stewardship</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="width: 80px;">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://static.vecteezy.com/system/resources/previews/009/292/244/non_2x/default-avatar-icon-of-social-media-user-vector.jpg" : item.ImageUrl)"
                                 alt="@item.Name"
                                 style="height: 64px; width: 64px; object-fit: cover; filter: sepia(0.15);">
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" style="font-family: var(--font-display); font-size: 1.15rem; font-weight: 600; color: var(--ink);">
                                @item.Name
                            </a>
                        </td>
                        <td class="text-muted text-truncate" style="max-width: 400px; font-style: italic;">
                            @item.Biography
                        </td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td class="text-end text-nowrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Revise</a>
                                <button type="button" class="btn btn-sm btn-ghost" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.Id">Remove</button>
                            </td>
                        }
                    </tr>

                    <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Remove from register</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    Remove <strong>@item.Name</strong> from the house register?
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Keep</button>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-primary">Remove</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>
