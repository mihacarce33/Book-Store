@model BookStore.Models.Author

@{
    ViewBag.Title = "Author Details";
    var defaultImageUrl = "https://static.vecteezy.com/system/resources/previews/009/292/244/non_2x/default-avatar-icon-of-social-media-user-vector.jpg";
    var authorImageUrl = string.IsNullOrEmpty(Model.ImageUrl) ? defaultImageUrl : Model.ImageUrl;
}

<h2 class="text-center mb-4">Author Details</h2>

<div class="container">
    <div class="card shadow-sm p-4 mb-4">
        <div class="d-flex align-items-center mb-4">
            <img src="@authorImageUrl"
                 alt="Author Image"
                 class="rounded-circle"
                 style="width: 150px; height: 150px; object-fit: cover; margin-right: 20px;" />
            <h4 class="mb-0">@Html.DisplayFor(model => model.Name)</h4>
        </div>
        <hr />
        <h5>Biography</h5>
        <p>@Html.DisplayFor(model => model.Biography)</p>
    </div>

    <div class="card shadow-sm p-4 mb-4">
        <h4 class="mb-3">Books by @Model.Name</h4>
        @if (Model.Books.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th style="width: 100px;">Cover</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th style="width: 150px;">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model.Books)
                    {
                        <tr>
                            <td style="font-size: 1.15rem; font-weight: bold; vertical-align: middle;">
                                @Html.ActionLink(book.Title, "Details", "Books", new { id = book.Id }, new { @class = "text-decoration-none" })
                            </td>
                            <td>
                                <a href="@Url.Action("Details", "Books", new { id = book.Id })">
                                    <img src="@book.ImageURL" alt="Book Image" class="rounded" style="width: 80px; height: 120px; object-fit: cover;" />
                                </a>
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td>
                                    @using (Html.BeginForm("RemoveBook", "Authors", new { id = Model.Id, bookId = book.Id }, FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>

            </table>
        }
        else
        {
            <p class="text-muted">No books assigned to this author.</p>
        }

        @if (User.IsInRole("Admin"))
        {
            <div class="mt-4">
                <h5>Add a Book</h5>
                @using (Html.BeginForm("AddBook", "Authors", FormMethod.Post))
                {
                @Html.AntiForgeryToken()
                @Html.Hidden("id", Model.Id)

                <div class="form-group mb-3">
                    @Html.DropDownList("bookId", ViewBag.Books as SelectList, "Select a Book", new { @class = "form-control" })
                </div>
                <button type="submit" class="btn btn-primary">Add Book</button>
                }
            </div>
        }
    </div>



    <div class="d-flex justify-content-between">
        @if (User.IsInRole("Admin"))
        {
            @Html.ActionLink("Edit", "Edit", new { id = Model.Id }, new { @class = "btn btn-warning" })
        }
        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
    </div>
</div>
