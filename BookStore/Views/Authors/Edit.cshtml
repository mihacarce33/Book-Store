@model BookStore.Models.Author

@{
    ViewBag.Title = "Edit Author";
}

<h2 class="text-center mb-4">Edit Author</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="container">
        <div class="card shadow-sm p-4">
            <h4 class="mb-3">Author Details</h4>
            <hr />
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @Html.HiddenFor(model => model.Id)

            <!-- Author Name -->
            <div class="form-group mb-3">
                @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "form-label fw-bold" })
                @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
            </div>

            <!-- Biography -->
            <div class="form-group mb-3">
                @Html.LabelFor(model => model.Biography, htmlAttributes: new { @class = "form-label fw-bold" })
                @Html.TextAreaFor(model => model.Biography, new { @class = "form-control", rows = 4 })
                @Html.ValidationMessageFor(model => model.Biography, "", new { @class = "text-danger" })
            </div>

            <!-- Image URL -->
            <div class="form-group mb-3">
                @Html.LabelFor(model => model.ImageUrl, htmlAttributes: new { @class = "form-label fw-bold" })
                @Html.EditorFor(model => model.ImageUrl, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.ImageUrl, "", new { @class = "text-danger" })
            </div>

            <!-- Image Preview -->
            <div class="form-group mb-3">
                <label class="form-label fw-bold">Current Image</label>
                <div>
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl)
                        ? "https://static.vecteezy.com/system/resources/previews/009/292/244/non_2x/default-avatar-icon-of-social-media-user-vector.jpg"
                        : Model.ImageUrl)"
                         class="img-thumbnail"
                         alt="Author Image"
                         style="height: 150px; width: 150px; object-fit: cover;">
                </div>
            </div>

            <!-- Submit Button -->
            <div class="form-group d-flex justify-content-between mt-4">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
            </div>
        </div>
    </div>
}
