@model BookStore.Models.Author

@{
    ViewBag.Title = "Create Author";
}

<h2 class="text-center mb-4">Create Author</h2>

@using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm p-4">
        <h4 class="mb-4">Author Details</h4>
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group mb-3">
            @Html.LabelFor(model => model.Name, "Name", new { @class = "form-label" })
            @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter author's name" } })
            @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            @Html.LabelFor(model => model.Biography, "Biography", new { @class = "form-label" })
            @Html.TextAreaFor(model => model.Biography, new { @class = "form-control", placeholder = "Enter a brief biography", rows = 4 })
            @Html.ValidationMessageFor(model => model.Biography, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(model => model.ImageUrl, "Image URL", new { @class = "form-label" })
            @Html.EditorFor(model => model.ImageUrl, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter image URL" } })
            @Html.ValidationMessageFor(model => model.ImageUrl, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Create</button>
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })
        </div>
    </div>
}
