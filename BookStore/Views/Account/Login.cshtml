@model LoginViewModel
@{
    ViewBag.Title = "Sign In";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <h2>Welcome back</h2>
        <p class="auth-subtitle">Sign in to reserve volumes and view your selection.</p>

        <form asp-controller="Account" asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="your correspondence address" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label" style="font-family: var(--font-body); text-transform: none; letter-spacing: 0; font-size: 0.95rem; font-style: italic;"></label>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg mb-3">Enter</button>

            <p class="text-center mb-0" style="font-style: italic;">
                New to the house? <a asp-action="Register">Join the registry</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
