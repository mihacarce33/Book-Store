@model BookStore.Models.AddToRoleModel

<h2 class="text-center mb-4">Manage User Roles</h2>

<div class="container">
    <div class="card shadow-lg p-4 rounded-4">
        <table class="table table-hover table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th scope="col">Email</th>
                    <th scope="col">Current Roles</th>
                    <th scope="col">Change Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.PagedUsers)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@user.CurrentRoles</td>
                        <td>
                            <div class="d-flex align-items-center">
                                @using (Html.BeginForm("AddUserToRole", "Account", FormMethod.Post, new { @class = "d-flex align-items-center" }))
                                {
                                    @Html.Hidden("userId", user.UserId)

                                    <!-- Properly set up the dropdown list -->
                                    @Html.DropDownList(
                                        "newRole",
                                        new SelectList(
                                            Model.Roles,  // List of available roles
                                            user.CurrentRoles ?? "-- Select a role --"  // Set the user's current role if it exists
                                        ),
                                        "-- Select a role --",  // Default option text
                                        new { @class = "form-select me-2", @style = "width: 180px;" }
                                    )

                                    <button type="submit" class="btn btn-primary btn-sm">Change Role</button>
                                }
                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>

        <!-- Pagination Section -->
        <nav aria-label="User pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=@(Model.CurrentPage - 1)">Previous</a>
                    </li>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=@(Model.CurrentPage + 1)">Next</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
