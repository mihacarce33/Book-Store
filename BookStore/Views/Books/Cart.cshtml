@model List<BookStore.Models.CartItem>

@{
    ViewBag.Title = "Your Cart";
}

<h2 class="text-center mb-4">Your Cart</h2>

@if (Model != null && Model.Any())
{
    <div class="container">
        <div class="card shadow-sm p-4">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Title</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@item.ImageUrl" alt="Book Image" style="height: 60px; width: 40px; object-fit: cover; border-radius: 5px;">
                            </td>
                            <td>@item.Title</td>
                            <td>@item.Price$</td>
                            <td>@item.Quantity</td>
                            <td>@(item.Price * item.Quantity)$</td>
                            <td>
                                <a href="@Url.Action("RemoveFromCart", "Books", new { id = item.BookId, quantity = 1 })" class="btn btn-sm btn-warning me-1">
                                    Remove
                                </a>
                                <a href="@Url.Action("RemoveFromCart", "Books", new { id = item.BookId, quantity = item.Quantity })" class="btn btn-sm btn-danger">
                                    Remove All
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <p class="fw-bold fs-5">
                <span>Total:</span> @Model.Sum(item => item.Price * item.Quantity)$
            </p>

            <p>
                <a href="javascript:void(0);" class="btn btn-success btn-lg" onclick="return confirmCheckout()">Proceed to Checkout</a>
            </p>
        </div>
    </div>
}
else
{
    <div class="alert alert-info text-center" role="alert">
        Your cart is empty.
    </div>
}

<script type="text/javascript">
    function confirmCheckout() {
        var result = confirm("Are you sure you want to proceed to checkout?");

        if (result) {
            alert("Order completed!");
            window.location.href = '@Url.Action("Checkout", "Books")';
        }

        return false;
    }
</script>
