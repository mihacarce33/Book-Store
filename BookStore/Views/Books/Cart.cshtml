@model List<BookStore.Models.CartItem>

@{
    ViewBag.Title = "Your Selection";
    var total = Model != null ? Model.Sum(item => item.Price * item.Quantity) : 0f;
}

<section class="page-hero page-hero-light page-hero-compact">
    <h1>Your Selection</h1>
    <p class="hero-lead mb-0">Volumes held for you until you are ready to complete your acquisition.</p>
</section>

@if (Model != null && Model.Any())
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="cart-card">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col"></th>
                                <th scope="col">Title</th>
                                <th scope="col">Value</th>
                                <th scope="col">Qty</th>
                                <th scope="col">Subtotal</th>
                                <th scope="col"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="@item.ImageUrl" alt="@item.Title" class="book-thumb">
                                    </td>
                                    <td class="fw-semibold" style="font-family: var(--font-display); font-size: 1.1rem;">@item.Title</td>
                                    <td>@string.Format("{0:C}", item.Price)</td>
                                    <td>@item.Quantity</td>
                                    <td class="fw-semibold text-nowrap" style="color: var(--wine);">@string.Format("{0:C}", item.Price * item.Quantity)</td>
                                    <td class="text-end text-nowrap">
                                        <a href="@Url.Action("RemoveFromCart", "Books", new { id = item.BookId, quantity = 1 })"
                                           class="btn btn-sm btn-outline-secondary me-1" title="Remove one">−</a>
                                        <a href="@Url.Action("RemoveFromCart", "Books", new { id = item.BookId, quantity = item.Quantity })"
                                           class="btn btn-sm btn-ghost" title="Remove all">Remove</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <p class="mt-4">
                <a asp-action="Index" class="btn btn-ghost">← Continue browsing the collection</a>
            </p>
        </div>
        <div class="col-lg-4">
            <div class="cart-summary sticky-top" style="top: 1.5rem;">
                <h5>Summary</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted" style="font-style: italic;">Volumes</span>
                    <span>@Model.Sum(i => i.Quantity)</span>
                </div>
                <hr style="border-color: var(--gold-pale);" />
                <div class="d-flex justify-content-between align-items-baseline mb-4">
                    <span style="font-family: var(--font-caps); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;">Total</span>
                    <span class="total-amount">@string.Format("{0:C}", total)</span>
                </div>
                <a href="javascript:void(0);" class="btn btn-primary btn-lg w-100" onclick="return confirmCheckout()">
                    Complete acquisition
                </a>
            </div>
        </div>
    </div>
}
else
{
    <div class="cart-empty">
        <h4>Your selection is empty</h4>
        <p class="text-muted mb-4">The reading room awaits. Wander the shelves and choose what speaks to you.</p>
        <a asp-action="Index" class="btn btn-primary btn-lg">Enter the collection</a>
    </div>
}

@section scripts {
<script type="text/javascript">
    function confirmCheckout() {
        if (confirm("Confirm your acquisition? We shall prepare your volumes with care.")) {
            window.location.href = '@Url.Action("Checkout", "Books")';
        }
        return false;
    }
</script>
}
