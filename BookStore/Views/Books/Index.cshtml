@model IEnumerable<BookStore.Models.Book>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewBag.Title = "The Collection";
    var genres = ViewBag.Genres as SelectList;
    var selectedGenreId = Context.Request.Query["genreId"].ToString();
    var selectedPriceSort = Context.Request.Query["priceSort"].ToString();
}

<section class="page-hero">
    <h1 class="display-5">The Collection</h1>
    <p class="hero-lead">Volumes chosen with care — first editions, forgotten classics, and works that deserve a place upon the shelf.</p>
</section>

<div class="filter-toolbar">
    <div class="row g-4 align-items-end">
        <div class="col-md-4">
            <label for="genreFilter" class="form-label">By Subject</label>
            <select id="genreFilter" class="form-select" onchange="filterBooks()">
                <option value="">All Shelves</option>
                @if (genres != null)
                {
                    @foreach (var genre in genres)
                    {
                        if (genre.Value == selectedGenreId)
                        {
                            <option value="@genre.Value" selected="selected">@genre.Text</option>
                        }
                        else
                        {
                            <option value="@genre.Value">@genre.Text</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-4">
            <label for="priceSort" class="form-label">Arrangement</label>
            <select id="priceSort" class="form-select" onchange="filterBooks()">
                <option value="">As catalogued</option>
                @if (selectedPriceSort == "asc") { <option value="asc" selected="selected">Value ascending</option> } else { <option value="asc">Value ascending</option> }
                @if (selectedPriceSort == "desc") { <option value="desc" selected="selected">Value descending</option> } else { <option value="desc">Value descending</option> }
            </select>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4 text-md-end">
                @Html.ActionLink("Catalogue a volume", "Create", null, new { @class = "btn btn-gold me-2" })
                @Html.ActionLink("Acquire from archive", "FetchFromApi", "Books", null, new { @class = "btn btn-outline-secondary" })
            </div>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="cart-empty">
        <h4>The shelves await</h4>
        <p class="text-muted">No volumes match your inquiry. Perhaps another subject, or return when the catalogue grows.</p>
    </div>
}
else
{
    <div class="ornament-divider">Selected Works</div>

    <div id="bookCards" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col book-card">
                <article class="card h-100">
                    <div class="card-img-wrap">
                        <img src="@item.ImageURL" class="card-img-top" alt="@item.Title">
                        @if (item.Genre != null)
                        {
                            <span class="genre-badge">@item.Genre.Name</span>
                        }
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h2 class="card-title h5">@Html.ActionLink(item.Title, "Details", new { id = item.Id })</h2>
                        <p class="book-meta mb-0">@(item.Author != null ? item.Author.Name : "Author unknown")</p>
                        @if (item.Price != null)
                        {
                            <p class="book-price mb-1">@string.Format("{0:C}", item.Price)</p>
                        }
                        <p class="card-text description" title="@item.Description">@item.Description</p>
                        <div class="mt-auto">
                            @if (item.Stock > 0)
                            {
                                <span class="stock-note available">Available — @item.Stock in the shop</span>
                            }
                            else
                            {
                                <span class="stock-note unavailable">Presently unavailable</span>
                            }
                        </div>
                        @if ((User.IsInRole("Admin") || User.IsInRole("User")) && item.Price != null && item.Stock > 0)
                        {
                            <div class="d-flex gap-2 align-items-center mt-3 pt-3" style="border-top: 1px solid var(--parchment-dark)">
                                <input type="number" id="quantity-@item.Id" min="1" max="@item.Stock" value="1" class="form-control quantity-input" aria-label="Quantity">
                                <button type="button" class="btn btn-primary flex-grow-1" onclick="addToCart(@item.Id)">Reserve</button>
                            </div>
                        }
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="card-footer d-flex justify-content-between">
                            @Html.ActionLink("Revise", "Edit", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-secondary" })
                            <button type="button" class="btn btn-sm btn-ghost btn-delete-book"
                                    data-book-id="@item.Id" data-book-title="@item.Title">
                                Remove from catalogue
                            </button>
                        </div>
                    }
                </article>
            </div>
        }
    </div>
}

<div id="paginationControls" class="d-flex justify-content-center flex-wrap gap-2 mt-5"></div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Withdraw from catalogue</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Remove <strong id="bookTitle"></strong> from the house records? This cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Keep listed</button>
                @using (Html.BeginForm("Delete", "Books", FormMethod.Post, new { id = "deleteForm" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="bookIdToDelete" name="id" />
                    <button type="submit" class="btn btn-primary">Withdraw</button>
                }
            </div>
        </div>
    </div>
</div>

@section scripts {
<script type="text/javascript">
    function addToCart(bookId) {
        var quantity = document.getElementById('quantity-' + bookId).value;
        if (quantity && quantity > 0) {
            window.location.href = '@Url.Action("AddToCart", "Books")/' + bookId + '?quantity=' + quantity;
        } else {
            alert("Pray specify a quantity.");
        }
    }

    $(document).on('click', '.btn-delete-book', function () {
        document.getElementById('bookTitle').textContent = $(this).data('book-title');
        document.getElementById('bookIdToDelete').value = $(this).data('book-id');
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    });

    function filterBooks() {
        var genreId = document.getElementById('genreFilter').value;
        var priceSort = document.getElementById('priceSort').value;
        var url = '@Url.Action("Index", "Books")';
        var params = [];
        if (genreId) params.push("genreId=" + genreId);
        if (priceSort) params.push("priceSort=" + priceSort);
        if (params.length > 0) url += "?" + params.join("&");
        window.location.href = url;
    }

    $(document).ready(function () {
        var itemsPerPage = 6;
        var items = $(".book-card");
        var totalItems = items.length;
        if (totalItems === 0) return;

        var totalPages = Math.ceil(totalItems / itemsPerPage);
        var currentPage = 1;

        function showPage(page) {
            items.hide();
            var startIndex = (page - 1) * itemsPerPage;
            items.slice(startIndex, startIndex + itemsPerPage).show();
            currentPage = page;
            renderPaginationControls();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function renderPaginationControls() {
            var paginationHtml = "";
            if (currentPage > 1) {
                paginationHtml += '<button class="btn btn-outline-secondary pagination-button" data-page="' + (currentPage - 1) + '">Previous</button>';
            }
            function addPageButton(page, isActive) {
                var cls = isActive ? 'btn-primary' : 'btn-outline-secondary';
                paginationHtml += '<button class="btn ' + cls + ' pagination-button" data-page="' + page + '">' + page + '</button>';
            }
            if (totalPages <= 7) {
                for (var i = 1; i <= totalPages; i++) addPageButton(i, i === currentPage);
            } else {
                addPageButton(1, currentPage === 1);
                if (currentPage > 3) paginationHtml += '<span class="px-2 text-muted">…</span>';
                var startPage = Math.max(2, currentPage - 1);
                var endPage = Math.min(totalPages - 1, currentPage + 1);
                for (var j = startPage; j <= endPage; j++) {
                    if (j > 1 && j < totalPages) addPageButton(j, j === currentPage);
                }
                if (currentPage < totalPages - 2) paginationHtml += '<span class="px-2 text-muted">…</span>';
                addPageButton(totalPages, currentPage === totalPages);
            }
            if (currentPage < totalPages) {
                paginationHtml += '<button class="btn btn-outline-secondary pagination-button" data-page="' + (currentPage + 1) + '">Next</button>';
            }
            $("#paginationControls").html(paginationHtml);
        }

        $(document).on("click", ".pagination-button", function () {
            showPage($(this).data("page"));
        });

        showPage(1);
    });
</script>
}
