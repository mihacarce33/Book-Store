@inject ICartService CartService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title — Harrington & Sons</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-masthead">
        <p class="masthead-ornament mb-0">Rare &amp; Fine Editions · Est. 1892</p>
        <nav class="navbar navbar-expand-lg site-navbar">
            <div class="container">
                <a asp-controller="Books" asp-action="Index" class="navbar-brand">
                    Harrington <span style="font-weight:400">&amp;</span> Sons
                    <span class="brand-subtitle">Booksellers · Bindery · Reading Room</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Books" asp-action="Index">The Collection</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Authors" asp-action="Index">Authors</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">Our History</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Visit Us</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Genres" asp-action="Index">Genres</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="Index">Ledger</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="AddUserToRole">Patrons</a></li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-lg-center">
                        @if (User.IsInRole("Admin") || User.IsInRole("User"))
                        {
                            var cartCount = CartService.GetItemCount();
                            <li class="nav-item">
                                <a class="nav-link nav-selection" asp-controller="Books" asp-action="ViewCart">
                                    Your Selection@if (cartCount > 0) { <span class="cart-count">(@cartCount)</span> }
                                </a>
                            </li>
                        }
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container body-content">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-2" role="alert">
                @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row align-items-start g-4">
                <div class="col-md-5 text-center text-md-start">
                    <span class="footer-brand">Harrington &amp; Sons</span>
                    <p class="footer-tagline mb-0">Where every volume carries the weight of a story well told.</p>
                    <span class="footer-est">Established MDCCCXCII</span>
                </div>
                <div class="col-md-7 text-center text-md-end">
                    <a asp-controller="Books" asp-action="Index" class="d-inline-block me-3 mb-2">The Collection</a>
                    <a asp-controller="Home" asp-action="About" class="d-inline-block me-3 mb-2">Our History</a>
                    <a asp-controller="Home" asp-action="Contact" class="d-inline-block mb-2">Visit Us</a>
                </div>
            </div>
            <hr />
            <p class="copyright mb-0">&copy; @DateTime.Now.Year Harrington &amp; Sons · All rights reserved</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("scripts", required: false)
</body>
</html>
