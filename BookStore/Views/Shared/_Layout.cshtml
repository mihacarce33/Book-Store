<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - BookStore</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        /* Custom navbar styling */
        .navbar {
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .navbar-brand, .nav-link {
            font-weight: bold;
        }

            .nav-link:hover {
                text-decoration: underline;
            }
        /* Footer styling */
        footer {
            background-color: #f8f9fa;
            padding: 1rem 0;
            text-align: center;
            color: #6c757d;
        }
        /* Cart icon styling */
        .fa-shopping-cart {
            font-size: 1.2rem;
            margin-right: 0.3rem;
        }
        /* Body content padding */
        .body-content {
            padding: 2rem 0;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <!-- Logo and Brand Link -->
            <a href="@Url.Action("Index", "Books")" class="navbar-brand d-flex align-items-center">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS6IugSOE4YFNfRKis-N_gkVzo3ai0E2GgLfQ&s" alt="BookStore Logo" class="me-2" style="height: 40px; width: 40px; object-fit: cover; border-radius: 50%;">
                <span>BookStore</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">@Html.ActionLink("Authors", "Index", "Authors", new { area = "" }, new { @class = "nav-link" })</li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">@Html.ActionLink("Genres", "Index", "Genres", new { area = "" }, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Orders", "Index", "Orders", new { area = "" }, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Order Items", "Index", "OrderItems", new { area = "" }, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Users", "Index", "Account/AddUserToRole", new { area = "" }, new { @class = "nav-link" })</li>
                    }
                    <li class="nav-item">@Html.ActionLink("About", "About", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                </ul>

                @if (User.IsInRole("Admin") || User.IsInRole("User"))
                {
                    <!-- Cart Icon with Count -->
                    var cart = Session["Cart"] as List<BookStore.Models.CartItem>;
                    int cartCount = cart != null ? cart.Sum(item => item.Quantity) : 0;

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a href="@Url.Action("ViewCart", "Books")" class="nav-link text-white">
                                <i class="fa fa-shopping-cart"></i> Cart (@cartCount)
                            </a>
                        </li>
                    </ul>
                }

                <!-- Login/Logout Partial -->
                @Html.Partial("_LoginPartial")
            </div>
        </div>
    </nav>


    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - BookStore</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script> <!-- For icons -->
    @RenderSection("scripts", required: false)
</body>
</html>
